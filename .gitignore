# Root Gitignore for Habilis Repository
# This repository contains multiple modules:
# - APP: The mobile/web React Vite PWA app
# - operativa: Operational documentation
# - papelera: Archived/old files

# Ignore IDE files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore deliverables/zips in root
*.zip
*.rar

# Ignore papelera
papelera/

# Ignore app specific untracked folders
APP/node_modules/
APP/dist/
